# === Секреты — НИКОГДА не коммитим ===
.env
*.env
*.key
*_key
*.pem
secrets.*

# === Тяжёлые результаты генераций (галереи изображений) ===
sessions/**/*.png
sessions/**/*.jpg
sessions/**/*.jpeg
sessions/**/*.webp
# Отобранные финалы и лог-файлы — коммитим:
!**/_selected/**
!**/log.json
# HTML-страницы сравнения оставляем в репо (они лёгкие):
!sessions/**/*.html

# === Эксперименты ===
experiments/**/*.png
experiments/**/*.jpg
!experiments/**/CONCLUSION.md

